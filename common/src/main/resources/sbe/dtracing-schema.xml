<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.etradingpoc.dtracing.common.sbe"
                   id="1"
                   version="1"
                   semanticVersion="5.2"
                   description="dtracing FX pricing pipeline — SBE message definitions"
                   byteOrder="littleEndian">

    <types>

        <!-- ── Standard SBE message framing header ─────────────────────────── -->
        <composite name="messageHeader" description="SBE message frame header">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId"  primitiveType="uint16"/>
            <type name="schemaId"    primitiveType="uint16"/>
            <type name="version"     primitiveType="uint16"/>
        </composite>

        <!-- ── Timestamp ────────────────────────────────────────────────────── -->
        <!--  int64 nanoseconds since Unix epoch (1970-01-01T00:00:00.000000000Z) -->
        <type name="NanoTimestamp"
              primitiveType="int64"
              semanticType="UTCTimestamp"
              description="Nanoseconds since Unix epoch"/>

        <!-- ── Fixed-point price: mantissa × 10^-5  (5 decimal places) ──────── -->
        <!--  e.g.  EURUSD 1.08765 is stored as mantissa = 108765, exponent = -5  -->
        <composite name="Decimal5" semanticType="Price"
                   description="Fixed-point decimal with 5 implied decimal places">
            <type name="mantissa" primitiveType="int64"/>
            <type name="exponent" primitiveType="int8" presence="constant">-5</type>
        </composite>

        <!-- ── ECN (Electronic Communication Network) ───────────────────────── -->
        <enum name="Ecn" encodingType="uint8"
              description="Source electronic communication network">
            <validValue name="EURONEXT" description="Euronext">0</validValue>
            <validValue name="EBS"      description="EBS – Electronic Broking Services">1</validValue>
            <validValue name="FENICS"   description="Fenics FX">2</validValue>
        </enum>

        <!-- ── FX Currency Pair ──────────────────────────────────────────────── -->
        <enum name="CcyPair" encodingType="uint8"
              description="ISO 4217 FX currency pair">
            <validValue name="EURUSD">0</validValue>
            <validValue name="GBPUSD">1</validValue>
            <validValue name="USDJPY">2</validValue>
            <validValue name="USDCHF">3</validValue>
            <validValue name="AUDUSD">4</validValue>
            <validValue name="USDCAD">5</validValue>
            <validValue name="NZDUSD">6</validValue>
            <validValue name="EURGBP">7</validValue>
            <validValue name="EURJPY">8</validValue>
            <validValue name="GBPJPY">9</validValue>
            <validValue name="EURCHF">10</validValue>
            <validValue name="AUDJPY">11</validValue>
        </enum>

        <!-- ── Pipeline stage (for distributed tracing) ───────────────────── -->
        <enum name="Stage" encodingType="uint8"
              description="Processing stage in the pricing pipeline">
            <validValue name="MDH_RECEIVE"  description="Market data handler — exchange publish to UDP receive">0</validValue>
            <validValue name="BOOK_BUILD"   description="Book builder — composite book rebuild">1</validValue>
            <validValue name="MID_PRICE"    description="Mid pricer — mid price calculation">2</validValue>
            <validValue name="PRICE_TIER"   description="Price tiering — spread application">3</validValue>
            <validValue name="MDH_PROCESS"  description="Market data handler — internal processing (decode, book update, publish)">4</validValue>
            <validValue name="TRANSPORT"    description="Aeron message transport between pipeline stages">5</validValue>
        </enum>

    </types>

    <!-- ════════════════════════════════════════════════════════════════════════
         Message 1 — FxMarketData
         Raw best-bid/offer tick received from an ECN feed.
         ════════════════════════════════════════════════════════════════════════ -->
    <message name="FxMarketData" id="1"
             description="Raw BBO tick from an ECN">
        <field name="ecn"            id="1"  type="Ecn"
               description="Source ECN"/>
        <field name="ccyPair"        id="2"  type="CcyPair"
               description="Currency pair"/>
        <field name="timestamp"      id="3"  type="NanoTimestamp"
               description="Feed timestamp – nanoseconds since Unix epoch"/>
        <field name="bidPrice"       id="4"  type="Decimal5"
               description="Best bid price (5 d.p.)"/>
        <field name="bidSize"        id="5"  type="int32"
               description="Bid notional size (thousands of base currency)"/>
        <field name="askPrice"       id="6"  type="Decimal5"
               description="Best ask price (5 d.p.)"/>
        <field name="askSize"        id="7"  type="int32"
               description="Ask notional size (thousands of base currency)"/>
        <field name="traceId"        id="8"  type="uint64"
               description="Trace ID — correlates spans across pipeline stages"/>
        <field name="spanId"         id="9"  type="uint64"
               description="Span ID created by the publishing stage"/>
        <field name="sequenceNumber" id="10" type="uint64"
               description="Original feed sequence number"/>
        <field name="senderTimestampOut" id="11" type="NanoTimestamp"
               description="Wall-clock nanoseconds when the publishing stage finished processing"/>
    </message>

    <!-- ════════════════════════════════════════════════════════════════════════
         Message 2 — CompositeBookSnapshot
         Full composite book — 3 positional venue slots indexed by ECN ordinal.
         Slot 0 = EURONEXT, Slot 1 = EBS, Slot 2 = FENICS.
         Zero bid/ask price means no data for that venue.
         ════════════════════════════════════════════════════════════════════════ -->
    <message name="CompositeBookSnapshot" id="2"
             description="Full composite book snapshot — 3 positional venue slots indexed by ECN ordinal">
        <field name="ccyPair"         id="1"  type="CcyPair"
               description="Currency pair"/>
        <field name="triggeringEcn"   id="2"  type="Ecn"
               description="ECN whose tick caused this rebuild"/>
        <field name="venue0BidPrice"  id="3"  type="Decimal5"
               description="EURONEXT bid price"/>
        <field name="venue0BidSize"   id="4"  type="int32"
               description="EURONEXT bid size"/>
        <field name="venue0AskPrice"  id="5"  type="Decimal5"
               description="EURONEXT ask price"/>
        <field name="venue0AskSize"   id="6"  type="int32"
               description="EURONEXT ask size"/>
        <field name="venue1BidPrice"  id="7"  type="Decimal5"
               description="EBS bid price"/>
        <field name="venue1BidSize"   id="8"  type="int32"
               description="EBS bid size"/>
        <field name="venue1AskPrice"  id="9"  type="Decimal5"
               description="EBS ask price"/>
        <field name="venue1AskSize"   id="10" type="int32"
               description="EBS ask size"/>
        <field name="venue2BidPrice"  id="11" type="Decimal5"
               description="FENICS bid price"/>
        <field name="venue2BidSize"   id="12" type="int32"
               description="FENICS bid size"/>
        <field name="venue2AskPrice"  id="13" type="Decimal5"
               description="FENICS ask price"/>
        <field name="venue2AskSize"   id="14" type="int32"
               description="FENICS ask size"/>
        <field name="traceId"         id="15" type="uint64"
               description="Trace ID — correlates spans across pipeline stages"/>
        <field name="spanId"          id="16" type="uint64"
               description="Span ID created by the publishing stage"/>
        <field name="sequenceNumber"  id="17" type="uint64"
               description="Original feed sequence number"/>
        <field name="senderTimestampOut" id="18" type="NanoTimestamp"
               description="Wall-clock nanoseconds when the publishing stage finished processing"/>
    </message>

    <!-- ════════════════════════════════════════════════════════════════════════
         Message 3 — MidPriceBook
         Mid price derived by the MidPricer from the aggregated order book.
         ════════════════════════════════════════════════════════════════════════ -->
    <message name="MidPriceBook" id="3"
             description="Calculated mid price for a currency pair">
        <field name="ccyPair"        id="1"  type="CcyPair"
               description="Currency pair"/>
        <field name="midPrice"       id="2"  type="Decimal5"
               description="Mid price (5 d.p.)"/>
        <field name="midSize"        id="3"  type="int32"
               description="Available size at mid"/>
        <field name="traceId"        id="4"  type="uint64"
               description="Trace ID — correlates spans across pipeline stages"/>
        <field name="spanId"         id="5"  type="uint64"
               description="Span ID created by the publishing stage"/>
        <field name="sequenceNumber" id="6"  type="uint64"
               description="Original feed sequence number"/>
        <field name="ecn"            id="7"  type="Ecn"
               description="Source ECN (carried for tracing context)"/>
        <field name="senderTimestampOut" id="8" type="NanoTimestamp"
               description="Wall-clock nanoseconds when the publishing stage finished processing"/>
    </message>

    <!-- ════════════════════════════════════════════════════════════════════════
         Message 4 — TieredPrice
         Client-facing tiered price produced by the PriceTiering engine.
         ════════════════════════════════════════════════════════════════════════ -->
    <message name="TieredPrice" id="4"
             description="Tiered/spread price distributed to clients">
        <field name="ccyPair"  id="1" type="CcyPair"
               description="Currency pair"/>
        <field name="tierNo"   id="2" type="uint8"
               description="Tier number (1 = tightest spread)"/>
        <field name="askPrice" id="3" type="Decimal5"
               description="Tiered ask price (5 d.p.)"/>
        <field name="askSize"  id="4" type="int32"
               description="Ask size for this tier"/>
        <field name="bidPrice" id="5" type="Decimal5"
               description="Tiered bid price (5 d.p.)"/>
        <field name="bidSize"  id="6" type="int32"
               description="Bid size for this tier"/>
    </message>

    <!-- ════════════════════════════════════════════════════════════════════════
         Message 5 — FxFeedDelta
         Inbound delta received over a raw UDP market-data feed.
         One datagram = one delta for a single currency pair.
         ════════════════════════════════════════════════════════════════════════ -->
    <message name="FxFeedDelta" id="5"
             description="Inbound UDP market-data delta">
        <field name="sequenceNumber" id="1" type="uint64"
               description="Monotonically increasing sequence number for gap detection"/>
        <field name="ccyPair"   id="2" type="CcyPair"
               description="Currency pair"/>
        <field name="timestamp" id="3" type="NanoTimestamp"
               description="Feed timestamp – nanoseconds since Unix epoch"/>
        <field name="askPrice"  id="4" type="Decimal5"
               description="Ask price (5 d.p.)"/>
        <field name="askSize"   id="5" type="int32"
               description="Ask notional size"/>
        <field name="bidPrice"  id="6" type="Decimal5"
               description="Bid price (5 d.p.)"/>
        <field name="bidSize"   id="7" type="int32"
               description="Bid notional size"/>
    </message>

    <!-- ════════════════════════════════════════════════════════════════════════
         Message 6 — TraceSpan
         Distributed tracing span published to the dedicated trace channel.
         Each pipeline stage emits one span per message processed.
         ════════════════════════════════════════════════════════════════════════ -->
    <message name="TraceSpan" id="6"
             description="Distributed tracing span for pipeline latency analysis">
        <field name="traceId"        id="1"  type="uint64"
               description="Trace ID — correlates spans across pipeline stages"/>
        <field name="spanId"         id="2"  type="uint64"
               description="Unique span ID for this processing step"/>
        <field name="parentSpanId"   id="3"  type="uint64"
               description="Span ID of the upstream stage (0 for root span)"/>
        <field name="stage"          id="4"  type="Stage"
               description="Pipeline stage that produced this span"/>
        <field name="ecn"            id="5"  type="Ecn"
               description="Source ECN"/>
        <field name="ccyPair"        id="6"  type="CcyPair"
               description="Currency pair"/>
        <field name="sequenceNumber" id="7"  type="uint64"
               description="Original feed sequence number"/>
        <field name="timestampIn"    id="8"  type="NanoTimestamp"
               description="Nanosecond wall-clock time when message was received"/>
        <field name="timestampOut"   id="9"  type="NanoTimestamp"
               description="Nanosecond wall-clock time when processing completed"/>
    </message>

</sbe:messageSchema>